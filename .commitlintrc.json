{
  "extends": ["@commitlint/config-conventional"],
  "rules": {
    "type-enum": [
      2,
      "always",
      ["feat", "fix", "style", "refactor", "perf", "content", "docs", "chore", "ux", "seo", "assets", "revert"]
    ],
    "scope-enum": [
      2,
      "always",
      ["hero", "projects", "dossier", "nav", "ui", "mobile", "routing", "brand", "css", "bosco", "footer", "not-found", "layout", "ci", "lab"]
    ],
    "subject-case": [2, "always", "lower-case"],
    "subject-full-stop": [2, "never", "."],
    "header-max-length": [2, "always", 72]
  }
}
